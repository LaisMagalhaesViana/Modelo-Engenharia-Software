generator client {
  provider        = "prisma-client"
  output          = "../node_modules/.prisma/client"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

//
enum TipoCategoria {
  RECEITA
  DESPESA
}
enum TipoLancamento {
  RECEITA
  DESPESA
}
enum FormaPagamento {
  PARCELAS
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  TRANSFERENCIA
}
enum TipoConta {
  CORRENTE
  POUPANÇA
}


//
model User{
  id  String @id @default(uuid())
  name String
  email String
  hashedPassword String
  monthlyIncome Decimal
  createdAt DateTime
  updatedAt DateTime @updatedAt
}

model Category {
  id  String @id @default(uuid())
  name String
  categoryType TipoCategoria
  color String
  createdAt DateTime
  updatedAt DateTime @updatedAt
}

// Lançamento
model Entry {
  id  String @id @default(uuid())
  type TipoLancamento
  value Decimal
  date DateTime
  description String
  paymentMethod FormaPagamento
  account TipoConta
  installmentsQuantity Int // parcelas
  createdAt DateTime
  updatedAt DateTime @updatedAt
}